# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Gradle build artifacts and caches
.gradle/
build/

# Local configuration (e.g., local SDK paths)
local.properties

# Log files
*.log

# Optional: Gradle GUI config
gradle-app.setting

# Avoid ignoring the Gradle Wrapper binary, as it's needed for portable builds
!gradle-wrapper.jar

# Cache of project task names
.gradletasknamecache
